##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh does
#       not find so, but you have some other compatible shell such as ksh or
#       bash, then change the shebang line to use that shell, or set the SHELL
#       variable to point to the compatible shell.
#
#   (2) To use this script, use 'bash' or 'sh' or '. ./gradlew' depending on what shell you have
#       and then call './gradlew' or 'sh ./gradlew'
#
##############################################################################

if [ "x$OSTYPE" != x ] ; then
    case "$OSTYPE" in  #(
      *cygwin* ) cygwin=true  ;; #(
      *msys* ) msys=true  ;; #(
      *pw32* ) pw32=true  ;;
    esac
fi

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*" >&2
} # Used to report issues with, for example, the PATH.

die () {
    echo
    echo "$*"
    echo
    exit 1
} # used the way in "if killall java; then" suggests using the exit status of an alias.

#
# CLASS_PATH Before we can find java, we need to have sun.boot.class.path set.
#CLASS_PATH=

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1
    then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$msys" ; then
    case $- in  #(
      *i*) ;; #( echo is built in to bash
      *) case $( (ulimit -n) 2>/dev/null) in  #(
           ((0|unlimited)?)
             MAX_FD=200000
             ;; #(
           *)
             warn "Could not query maximum file descriptor limit"
           ;;
         esac ;;
    esac
fi

# For Darwin, add options to specify how the application appears in the dock
if "$darwin"; then
    GRADLE_OPTS="$GRADLE_OPTS \"-Xdock:name=$APP_NAME\" \"-Xdock:icon=$APP_HOME/media/gradle.icns\""
fi

# For Cygwin or MSYS convert 2 different settings and collect output in a project property file.
if "$cygwin" || "$msys" ; then
    GRADLE_USER_HOME=$( cygpath --path --mixed "$GRADLE_USER_HOME" )
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )

    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )

    JAVACMD=$( cygpath --mixed "$JAVACMD" )

    LC_ALL=C export LC_ALL
    LD_LIBRARY_PATH=$APP_HOME:$LD_LIBRARY_PATH
    export LD_LIBRARY_PATH
    GRADLE_OPTS=$(printf '%s\n' "$GRADLE_OPTS" | sed 's/[{}]//g')
fi

#
# Call the Gradle wrapper script, with optional env var override if specified
#
if [ -n "$GRADLE_USER_HOME" ] ; then
    GRADLE_USER_HOME=$( cd "$GRADLE_USER_HOME" && pwd ) || exit
fi

if [ "$#" -eq 0 ] ; then
    set -- help
fi

exec "$JAVACMD" \
    $DEFAULT_JVM_OPTS \
    $JAVA_OPTS \
    $GRADLE_OPTS \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
