# ChordMini HTTPS reverse proxy for local/edge origins.
# This uses Caddy's internal CA by default (self-signed origin cert).
# For Cloudflare Tunnel, set origin request to HTTPS and disable origin cert validation.

:80 {
  redir https://{host}{uri} permanent
}

:443 {
  tls internal
  encode gzip zstd

  # Preserve proxy headers and route all traffic to Next.js frontend.
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Forwarded-Proto https
  }
}
